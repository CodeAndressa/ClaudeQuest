# Copie este arquivo para .env e preencha os valores reais. Nunca versione o .env.

# --- Aplicação ---
APP_NAME=ClaudeQuest
ENVIRONMENT=development
PORT=8002
APP_URL=http://localhost:8002
FRONTEND_URL=http://localhost:5180

# --- Banco de dados ---
DATABASE_URL=postgresql+asyncpg://claudequest:claudequest@localhost:5432/claudequest
POSTGRES_USER=claudequest
POSTGRES_PASSWORD=claudequest
POSTGRES_DB=claudequest

# --- Autenticação (ADR-007) ---
JWT_SECRET=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# --- Provedores de IA (ADR-006 — nunca depender diretamente de um único provider) ---
AI_PROVIDER=anthropic
ANTHROPIC_KEY=
OPENROUTER_KEY=

# --- E-mail transacional ---
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8002/api/v1
